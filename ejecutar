                            <th>Enviado (-)</th>
                            <th>Balance Neto</th>
                            <th>Donantes</th>
                        </tr>
                    </thead>
                    <tbody>
"""

    if not totals_rows:
        html_content += "<tr><td colspan='9' style='text-align:center; color:#9ca3af;'>No hay campañas registradas.</td></tr>"
    else:
        for row in totals_rows:
            status_badge = f"<span class='badge badge-active'>{row['status']}</span>" if row['status'] == 'active' else f"<span class='badge badge-paused'>{row['status']}</span>"
            html_content += f"""
                        <tr>
                            <td>{row['id']}</td>
                            <td class='text-bold'>{row['title']}</td>
                            <td>{status_badge}</td>
                            <td>${row['targetAmount']:.2f}</td>
                            <td class='text-green'>+${row['total_donations']:.2f}</td>
                            <td class='text-green'>+${row['total_transfers_received']:.2f}</td>
                            <td class='text-red'>-${row['total_transfers_sent']:.2f}</td>
                            <td class='text-bold' style='color:#06b6d4'>${row['current_balance']:.2f}</td>
                            <td>{row['donation_count']}</td>
                        </tr>"""

    html_content += """
                    </tbody>
                </table>
            </div>
        </div>

