#!/usr/bin/env python3
import os
import sqlite3
import webbrowser
import sys

# Definir rutas
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
DB_PATH = os.path.join(BASE_DIR, 'backend', 'database.sqlite')
HTML_PATH = os.path.join(BASE_DIR, 'visualizar_datos.html')

def check_db():
    if not os.path.exists(DB_PATH):
        print(f"ERROR: No se encontró el archivo de base de datos en: {DB_PATH}")
        print("Por favor, inicia primero el backend ejecutando ./start.sh para crear y sembrar la base de datos.")
        sys.exit(1)

def query_db(query, params=()):
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    try {
        cursor.execute(query, params)
        rows = cursor.fetchall()
        return rows
    except Exception as e:
        print(f"Error ejecutando query: {query}\nError: {e}")
        return []
    finally:
        conn.close()

def generate_html():
    check_db()
    
    # 1. Obtener estructura/esquema de las tablas y vistas
    schema_rows = query_db("SELECT type, name, sql FROM sqlite_master WHERE type IN ('table', 'view') AND name NOT LIKE 'sqlite_%';")
    
    # 2. Obtener datos de la Vista de Totales por Campaña
    totals_rows = query_db("SELECT * FROM CampaignTotals;")
    
    # 3. Obtener todas las donaciones detalladas
    donations_rows = query_db("""
        SELECT d.id, d.createdAt, d.donorName, d.amount, c.title AS campaign_title, d.comment 
        FROM Donations d 
        JOIN Campaigns c ON d.campaignId = c.id
        ORDER BY d.createdAt DESC;
    """)
    
    # 4. Obtener todas las transferencias detalladas
    transfers_rows = query_db("""
        SELECT t.id, t.createdAt, t.amount, t.reason, 
               c1.title AS source_title, c2.title AS target_title
        FROM Transfers t
        JOIN Campaigns c1 ON t.sourceCampaignId = c1.id
        JOIN Campaigns c2 ON t.targetCampaignId = c2.id
        ORDER BY t.createdAt DESC;
    """)

    # Comenzar a construir el contenido HTML
    html_content = """<!DOCTYPE html>
