        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Visualizador Estático de Datos y Estructura SQL</h1>
            <p class="subtitle">Datos extraídos en tiempo real de: <code>backend/database.sqlite</code></p>
        </header>

        <!-- 1. VISTA DE TOTALES -->
        <div class="section-card">
            <h2>📊 Consulta a la Vista SQL: CampaignTotals</h2>
            <div style="overflow-x: auto;">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Campaña</th>
