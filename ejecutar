                                <th>Monto</th>
                                <th>Campaña</th>
                                <th>Comentario</th>
                            </tr>
                        </thead>
                        <tbody>
"""

    if not donations_rows:
        html_content += "<tr><td colspan='4' style='text-align:center; color:#9ca3af;'>No hay donaciones registradas.</td></tr>"
    else:
        for row in donations_rows:
            html_content += f"""
                            <tr>
                                <td>{row['donorName']}</td>
                                <td class='text-green'>+${row['amount']:.2f}</td>
                                <td class='text-bold'>{row['campaign_title']}</td>
                                <td style='color:#9ca3af; font-size:0.8rem;'>{row['comment'] if row['comment'] else 'Sin comentarios'}</td>
                            </tr>"""

    html_content += """
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- 3. TRANSFERENCIAS -->
            <div class="section-card">
                <h2>🔄 Historial de Transferencias Atómicas</h2>
                <div style="overflow-x: auto;">
                    <table>
                        <thead>
                            <tr>
                                <th>Origen</th>
                                <th>Destino</th>
                                <th>Monto</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody>
"""

    if not transfers_rows:
        html_content += "<tr><td colspan='4' style='text-align:center; color:#9ca3af;'>No hay transferencias registradas.</td></tr>"
    else:
        for row in transfers_rows:
            html_content += f"""
                            <tr>
                                <td class='text-red'>{row['source_title']}</td>
                                <td class='text-green'>{row['target_title']}</td>
                                <td class='text-orange'>${row['amount']:.2f}</td>
                                <td style='color:#9ca3af; font-size:0.8rem;'>{row['reason']}</td>
                            </tr>"""

    html_content += """
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- 4. ESTRUCTURA Y DDL -->
        <div class="section-card">
            <h2>📐 Estructura de la Base de Datos (Esquema DDL)</h2>
            <div style="display:flex; flex-direction:column; gap:16px;">
"""

    for item in schema_rows:
        type_lbl = "TABLA" if item['type'] == 'table' else "VISTA"
        html_content += f"""
                <div>
                    <h3 style='margin:0 0 8px 0; font-size:0.95rem; color:#10b981;'>{type_lbl}: {item['name']}</h3>
                    <pre>{item['sql']};</pre>
                </div>"""

    html_content += """
            </div>
        </div>
    </div>
</body>
</html>"""

    # Guardar en archivo html
    with open(HTML_PATH, 'w', encoding='utf-8') as f:
        f.write(html_content)
    
    print(f"Reporte generado exitosamente en: {HTML_PATH}")
    
    # Abrir en el navegador por defecto
    webbrowser.open(f"file://{HTML_PATH}")

if __name__ == '__main__':
    generate_html()
